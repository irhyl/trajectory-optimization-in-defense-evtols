[MASTER]
# Configuration file for Pylint
# Code quality and style checker for Python
# Updated: November 2025

init-hook='import sys; sys.path.insert(0, "src")'
jobs=0
limit-inference-results=100
persistent=yes
unsafe-load-any-extension=no

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    too-many-arguments,
    too-many-locals,
    too-many-branches,
    too-many-instance-attributes,
    duplicate-code,
    line-too-long,
    invalid-name,
    protected-access,
    no-member,

[REPORTS]
output-format=colorized
reports=no
score=yes
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[REFACTORING]
max-nested-blocks=5
max-locals=15
max-branches=12

[FORMAT]
indent-after-paren=4
indent-string='    '
line-length=100
max-line-length=100

[LOGGING]
logging-format-style=new
logging-modules=logging,loguru

[SIMILARITIES]
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=no
min-similarity-lines=4

[SPELLING]
spelling-dict=en_US
spelling-ignore-words=
spelling-private-word-hint=no

[BASIC]
argument-naming-style=snake_case
attr-naming-style=snake_case
class-naming-style=PascalCase
class-attribute-naming-style=snake_case
const-naming-style=UPPER_CASE
function-naming-style=snake_case
inlinevar-naming-style=snake_case
method-naming-style=snake_case
module-naming-style=snake_case
variable-naming-style=snake_case
docstring-min-length=-1
good-names=i,j,k,ex,Run,_

[VARIABLES]
additional-builtins=
allow-global-with-name=
callbacks=cb_,_cb
dummy-variables-rgx=_+$|(_[a-zA-Z0-9_]*[a-zA-Z0-9]+?$)|dummy|^ignored_|^unused_
ignored-argument-names=_.*|^ignored_|^unused_
init-import=no
redefining-builtins-modules=six.moves,past.builtins,future.builtins,builtins,io

[DESIGN]
max-args=5
max-attributes=7
max-bool-expr=5
max-parents=7
max-public-methods=20
max-returns=6
max-statements=50
min-public-methods=2

[CLASSES]
check-protected-access-in-special-methods=no
defining-attr-methods=__init__,__new__,setUp,_initialize
exclude-protected=_asdict,_fields,_make,_replace,__slots__
valid-classmethod-first-arg=cls
valid-metaclass-first-arg=cls

[IMPORTS]
allow-wildcard-with-all=no
deprecated-modules=optparse,tkinter.tix

[EXCEPTIONS]
overgeneral-exceptions=Exception
