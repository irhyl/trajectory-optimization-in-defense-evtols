{
  "@context": "https://schema.org/",
  "@type": "Dataset",
  "name": "Defense eVTOL Perception Dataset \u2014 Delhi NCR Theatre",
  "description": "Multi-layer perception dataset for defense eVTOL trajectory optimization. 1,057,714 rows covering terrain (SRTM), wind (GFS/HRES), obstacles (OSM), and SAM threat assessment (Swerling-I) over the Delhi NCR theatre.",
  "url": "https://github.com/evtol-research/trajectory-optimization-in-defense-evtols",
  "version": "2.0.0",
  "datePublished": "2026-04-04T07:13:16.100771+00:00",
  "creator": {
    "@type": "Organization",
    "name": "Defense eVTOL Research Team"
  },
  "spatialCoverage": {
    "@type": "Place",
    "name": "Delhi NCR outskirts, India",
    "geo": {
      "@type": "GeoShape",
      "box": "28.4 76.9 28.9 77.5"
    }
  },
  "temporalCoverage": "2026-04-04",
  "variableMeasured": [
